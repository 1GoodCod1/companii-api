{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.build.json"
  },
  "watchOptions": {
    "usePolling": true,
    "aggregateTimeout": 2500,
    "ignored": ["**/node_modules/**", "**/dist/**", "**/logs/**", "**/uploads/**"]
  }
}
