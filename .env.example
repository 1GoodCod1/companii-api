NODE_ENV=development
PORT=4100

# Admin seed (dev defaults if unset: admin@companii.local / Admin12345!)
# ADMIN_EMAIL=admin@companii.local
# ADMIN_PASSWORD=Admin12345!

# Public URLs (prod: обязательны https:// — проверяются при старте)
API_URL=http://localhost:4100
FRONTEND_URL=http://localhost:5174
DATABASE_URL=postgresql://companii_app:companii_app_pass@localhost:5433/companii

MIGRATION_DATABASE_URL=postgresql://postgres:companii@localhost:5433/companii
REDIS_URL=redis://localhost:6380

# Access JWT (Bearer header)
JWT_SECRET=change-me-companii-jwt-secret-min-32-chars
JWT_EXPIRES_IN=15m
USE_HTTPONLY_COOKIE=true
REFRESH_COOKIE_NAME=companii_refresh
COOKIE_DOMAIN=

COOKIE_ORIGIN_CHECK=true

AUDIT_HTTP_ENABLED=true
FILES_UPLOAD_DIR=./uploads

EMAIL_ENABLED=true
EMAIL_FROM=Faber Companii <noreply@faber.md>
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your-mailtrap-username
SMTP_PASS=your-mailtrap-password
