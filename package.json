{
  "name": "companii-api",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "node --trace-deprecation ./node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest --config ./test/jest-unit.json",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:watch": "jest --config ./test/jest-unit.json --watch",
    "test:cov": "jest --config ./test/jest-unit.json --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:status": "prisma migrate status",
    "prisma:reset": "prisma migrate reset --force",
    "seed": "ts-node prisma/seed.ts",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d --build",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "docker:build": "docker compose -f docker-compose.dev.yml build",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f api",
    "docker:dev:up": "docker compose -f docker-compose.dev.yml up -d --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:dev:rebuild": "docker compose -f docker-compose.dev.yml up -d --build --force-recreate",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml build",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f api",
    "docker:prod:build": "docker compose -f docker-compose.prod.yml build",
    "docker:prod:rebuild": "docker compose -f docker-compose.prod.yml up -d --build --force-recreate",
    "docker:prune": "npm run docker:prune:dev && npm run docker:prune:prod",
    "docker:prune:dev": "docker compose -f docker-compose.dev.yml down -v --remove-orphans --rmi local",
    "docker:prune:prod": "docker compose -f docker-compose.prod.yml down -v --remove-orphans --rmi local",
    "docker:seed": "docker exec companii-api-dev npm run seed",
    "docker:migrate": "docker exec companii-api-dev npx prisma migrate deploy",
    "docker:generate": "docker exec companii-api-dev npx prisma generate",
    "docker:migrate:reset": "docker exec companii-api-dev npx prisma migrate reset --force",
    "docker:migrate:dev": "docker exec companii-api-dev npx prisma migrate deploy",
    "docker:migrate:create": "docker exec -it companii-api-dev npx prisma migrate dev",
    "docker:studio": "docker compose -f docker-compose.dev.yml up -d prisma-studio",
    "docker:studio:logs": "docker compose -f docker-compose.dev.yml logs -f prisma-studio",
    "redis:cli": "docker exec -it companii-redis redis-cli",
    "redis:ping": "docker exec -it companii-redis redis-cli ping",
    "redis:keys": "docker exec companii-redis redis-cli KEYS \"cache:*\"",
    "redis:flush": "docker exec companii-redis redis-cli FLUSHDB",
    "update:deps": "npx npm-check-updates -u",
    "update:deps:check": "npx npm-check-updates",
    "local:recreate:db": "npx prisma migrate deploy && npm run prisma:generate && npm run seed",
    "docker:dev:create": "npm run docker:dev:build && npm run docker:dev:up && npm run docker:migrate:reset && npm run docker:migrate:dev && npm run docker:generate && npm run docker:seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/pdfkit": "^0.17.6",
    "argon2": "^0.44.0",
    "bullmq": "^5.77.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "multer-s3": "^3.0.1",
    "nest-winston": "^1.10.2",
    "nodemailer": "^8.0.8",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.2",
    "uuid": "^13.0.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
