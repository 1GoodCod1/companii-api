# Docker dev stack (docker-compose.dev.yml → env_file: .env.docker)
NODE_ENV=development
PORT=4100
TZ=Europe/Chisinau

API_URL=http://localhost:4100
FRONTEND_URL=http://localhost:5174

DATABASE_URL=postgresql://postgres:companii@postgres:5432/companii
REDIS_URL=redis://redis:6379

JWT_SECRET=dev-companii-jwt-secret-min-32-characters-long
JWT_EXPIRES_IN=15m

# CORS — опционально; по умолчанию FRONTEND_URL + localhost:5174
# CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

USE_HTTPONLY_COOKIE=true
REFRESH_COOKIE_NAME=companii_refresh
COOKIE_DOMAIN=
COOKIE_ORIGIN_CHECK=false

AUDIT_HTTP_ENABLED=true
FILES_UPLOAD_DIR=./uploads

EMAIL_ENABLED=false
EMAIL_FROM=Faber Companii <noreply@faber.md>
SMTP_HOST=
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
