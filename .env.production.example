# =============================================================================
# PRODUCTION — шаблон переменных окружения (Faber Companii API)
# =============================================================================
# cp .env.production.example .env  → заполните секреты → docker compose -f docker-compose.prod.yml up -d
# НЕ коммитьте .env в Git!
# =============================================================================

NODE_ENV=production
PORT=4100
API_URL=https://api.companii.faber.md
FRONTEND_URL=https://companii.faber.md

# Database
DATABASE_URL=postgresql://postgres:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/companii
POSTGRES_DB=companii
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# JWT — сгенерируйте: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-production-jwt-secret-min-32-chars
JWT_EXPIRES_IN=15m

# CORS — в prod достаточно FRONTEND_URL; CORS_ORIGINS только если несколько origin
# CORS_ORIGINS=https://companii.faber.md

# Auth cookies
USE_HTTPONLY_COOKIE=true
REFRESH_COOKIE_NAME=companii_refresh
COOKIE_DOMAIN=.faber.md

AUDIT_HTTP_ENABLED=true
FILES_UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# Backblaze B2 (S3-compatible) — REQUIRED in production
# -----------------------------------------------------------------------------
# Создайте две bucket'ы в b2:
#   1. <prefix>-public  -> Bucket Type = Public (раздаётся напрямую, для аватарок/галерей)
#   2. <prefix>-private -> Bucket Type = Private (для чеков/документов, идёт через API)
# Затем создайте Application Key с правом writeFiles/readFiles/deleteFiles
# на ОБА bucket'а и подставьте сюда.
# Без этих переменных API в проде НЕ СТАРТУЕТ (anti-foot-gun).
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_PUBLIC_BUCKET=companii-public
B2_PRIVATE_BUCKET=companii-private
B2_REGION=eu-central-003
# Опционально — кастомный S3 endpoint (например, через приватный CNAME).
# B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
# Опционально — CDN перед публичным bucket'ом (Bunny.net, Cloudflare, ...).
# Если задано, публичные URL будут вида B2_PUBLIC_BASE_URL/uploads/<uuid>.ext
# B2_PUBLIC_BASE_URL=https://cdn.companii.faber.md

# Email
EMAIL_ENABLED=true
EMAIL_FROM=Faber Companii <noreply@faber.md>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
