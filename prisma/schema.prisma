generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum AccountKind {
  COMPANY_STAFF
  END_CLIENT
  PLATFORM_ADMIN
}

enum CompanyRole {
  OWNER
  MANAGER
  MEMBER
}

enum CompanyMemberStatus {
  PENDING
  ACTIVE
  LEFT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CompanySubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

enum CompanySubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum InterventionStatus {
  NEW
  SCHEDULED
  EN_ROUTE
  IN_PROGRESS
  COMPLETED
  INVOICED
  PAID
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CONVERTED
}

enum InvoicePaymentStatus {
  UNPAID
  PAID
  OVERDUE
}

enum ConsentType {
  TEAM_DATA_PROCESSING
  PORTAL_DATA_PROCESSING
}

enum ReviewStatus {
  PENDING
  VISIBLE
  HIDDEN
}

enum EstimateProjectStatus {
  DRAFT
  MEASURED
  CALCULATED
  APPROVED
  SENT
  ACCEPTED
  IN_EXECUTION
  DONE
  CANCELLED
}

enum EstimateStageKind {
  LABOR
  MATERIAL
  MIXED
}

enum CompanyLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  IN_PROGRESS
  CONVERTED
  LOST
}

enum CompanyLeadSource {
  SERVICE_REQUEST
  PROJECT_REQUEST
  MANUAL
  PHONE
  WEBSITE
}

enum PaymentProductType {
  COMPANY_SUBSCRIPTION
}

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  phone           String?     @unique
  passwordHash    String?     @map("password_hash")
  accountKind     AccountKind @map("account_kind")
  firstName       String?     @map("first_name")
  lastName        String?     @map("last_name")
  termsAcceptedAt DateTime?   @map("terms_accepted_at")
  termsVersion    String?     @map("terms_version")
  isActive        Boolean     @default(true) @map("is_active")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  ownedCompanies     Company[]           @relation("CompanyOwner")
  companyMemberships CompanyMember[]
  portalCustomer     CompanyCustomer?
  refreshTokens      RefreshToken[]
  auditLogs          AuditLog[]
  uploadedFiles      File[]
  companyReviews     CompanyReview[] @relation("ReviewAuthor")
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

enum FileVisibility {
  PUBLIC
  PRIVATE
}

model File {
  id           String         @id @default(uuid())
  filename     String
  path         String         @unique
  mimetype     String
  size         Int
  visibility   FileVisibility @default(PRIVATE)
  uploadedById String?        @map("uploaded_by_id")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  uploader User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([mimetype])
  @@index([visibility])
  @@map("files")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  oldData    Json?
  newData    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model City {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique
  translations Json?
  companies    Company[]

  @@map("cities")
}

model Category {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique
  translations Json?
  companies          Company[]
  companyServices    CompanyService[]
  estimateBlueprints EstimateBlueprint[]
  estimateProjects   EstimateProject[]
  leads              CompanyLead[]

  @@map("categories")
}

model Company {
  id           String   @id @default(uuid())
  slug         String   @unique
  ownerUserId  String   @map("owner_user_id")
  name         String
  legalName    String   @map("legal_name")
  idno         String   @unique @db.VarChar(13)
  legalAddress String   @map("legal_address")
  isTvaPayer   Boolean  @default(false) @map("is_tva_payer")
  tvaCode      String?  @map("tva_code")
  description  String?
  cityId       String   @map("city_id")
  categoryId   String?  @map("category_id")
  contactPhone String?  @map("contact_phone")
  contactEmail String?  @map("contact_email")
  showPublicPhone  Boolean  @default(true) @map("show_public_phone")
  showPublicEmail  Boolean  @default(true) @map("show_public_email")
  rating       Decimal  @default(0) @db.Decimal(3, 2)
  totalReviews Int      @default(0) @map("total_reviews")
  teamSize     Int      @default(0) @map("team_size")
  isPublished  Boolean  @default(false) @map("is_published")
  isVerified   Boolean  @default(false) @map("is_verified")
  logoUrl      String?  @map("logo_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  owner        User                 @relation("CompanyOwner", fields: [ownerUserId], references: [id])
  city         City                 @relation(fields: [cityId], references: [id])
  category     Category?            @relation(fields: [categoryId], references: [id])
  members      CompanyMember[]
  invitations  CompanyInvitation[]
  documents    CompanyDocument[]
  consents     CompanyConsent[]
  customers    CompanyCustomer[]
  leads            CompanyLead[]
  interventions    Intervention[]
  services         CompanyService[]
  quotes           Quote[]
  estimateProjects EstimateProject[]
  estimateReceipts EstimateReceipt[]
  invoices     CompanyInvoice[]
  subscription CompanySubscription?
  badges       Badge[]
  galleryImages CompanyGalleryImage[]
  reviews          CompanyReview[]

  @@index([cityId])
  @@index([isPublished, isVerified])
  @@map("companies")
}

model CompanyWaitlist {
  id          String   @id @default(uuid())
  email       String
  companyName String   @map("company_name")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("company_waitlist")
}

model CompanyMember {
  id                 String              @id @default(uuid())
  companyId          String              @map("company_id")
  userId             String              @map("user_id")
  role               CompanyRole
  status             CompanyMemberStatus @default(PENDING)
  fullName           String?             @map("full_name")
  phone              String?
  email              String?
  specialization     String?
  isActive           Boolean             @default(true) @map("is_active")
  contractAcceptedAt DateTime?           @map("contract_accepted_at")
  joinedAt           DateTime?           @map("joined_at")
  leftAt             DateTime?           @map("left_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  interventions Intervention[] @relation("TechnicianInterventions")
  statusChanges InterventionStatusHistory[]
  notes         InterventionNote[]

  @@unique([companyId, userId])
  @@map("company_members")
}

model CompanyInvitation {
  id            String           @id @default(uuid())
  companyId     String           @map("company_id")
  invitedEmail  String?          @map("invited_email")
  invitedUserId String?          @map("invited_user_id")
  token         String           @unique
  status        InvitationStatus @default(PENDING)
  role          CompanyRole      @default(MEMBER)
  expiresAt     DateTime         @map("expires_at")
  respondedAt   DateTime?        @map("responded_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_invitations")
}

model CompanyDocument {
  id         String             @id @default(uuid())
  companyId  String             @map("company_id")
  type       String
  fileKey    String             @map("file_key")
  status     VerificationStatus @default(PENDING)
  reviewedAt DateTime?          @map("reviewed_at")
  createdAt  DateTime           @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_documents")
}

model CompanyGalleryImage {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  url       String
  caption   String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, sortOrder])
  @@map("company_gallery_images")
}

model CompanyConsent {
  id           String      @id @default(uuid())
  companyId    String      @map("company_id")
  memberId     String      @map("member_id")
  consentType  ConsentType @map("consent_type")
  granted      Boolean
  lawfulBasis  String      @map("lawful_basis")
  version      String
  ipAddress    String?     @map("ip_address")
  revokedAt    DateTime?   @map("revoked_at")
  createdAt    DateTime    @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, memberId, consentType])
  @@map("company_consents")
}

model CompanyService {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  slug            String   @unique
  name            String
  description     String   @default("")
  categoryId      String?  @map("category_id")
  defaultPrice    Decimal  @map("default_price") @db.Decimal(12, 2)
  currency        String   @default("MDL")
  durationMinutes Int?     @map("duration_minutes")
  materialsCost   Decimal? @map("materials_cost") @db.Decimal(12, 2)
  vatRate         Decimal? @map("vat_rate") @db.Decimal(5, 2)
  isPublished     Boolean  @default(false) @map("is_published")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  lines    QuoteLine[]

  @@index([companyId, isPublished])
  @@map("company_services")
}

model CompanyPlan {
  id                       String                  @id @default(uuid())
  code                     CompanySubscriptionPlan @unique
  name                     String
  price                    Decimal                 @db.Decimal(12, 2)
  currency                 String                  @default("MDL")
  maxTechnicians           Int?                    @map("max_technicians")
  maxInterventionsPerMonth Int?                    @map("max_interventions_per_month")
  features                 Json                    @default("{}")
  createdAt                DateTime                @default(now()) @map("created_at")

  subscriptions CompanySubscription[]

  @@map("company_plans")
}

model CompanySubscription {
  id                 String                    @id @default(uuid())
  companyId          String                    @unique @map("company_id")
  planId             String                    @map("plan_id")
  status             CompanySubscriptionStatus @default(TRIAL)
  currentPeriodEnd   DateTime                  @map("current_period_end")
  activatedByAdminId String?                   @map("activated_by_admin_id")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan    CompanyPlan @relation(fields: [planId], references: [id])

  @@map("company_subscriptions")
}

model CompanyCustomer {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  portalUserId String?  @unique @map("portal_user_id")
  fullName     String   @map("full_name")
  phone        String
  email        String?
  address      String
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company       Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  portalUser    User?                      @relation(fields: [portalUserId], references: [id])
  documents     CompanyCustomerDocument[]
  interventions Intervention[]
  quotes            Quote[]
  estimateProjects  EstimateProject[]
  portalInvites PortalInvitation[]
  reviews       CompanyReview[]
  leads         CompanyLead[]

  @@index([companyId])
  @@map("company_customers")
}

model CompanyLead {
  id           String            @id @default(uuid())
  companyId    String            @map("company_id")
  customerId   String?           @map("customer_id")
  contactName  String            @map("contact_name")
  contactPhone String            @map("contact_phone")
  contactEmail String?           @map("contact_email")
  message      String?
  address      String?
  status       CompanyLeadStatus @default(NEW)
  source       CompanyLeadSource @default(MANUAL)
  categoryId   String?           @map("category_id")
  serviceTitle       String?           @map("service_title")
  estimatedBudget    Decimal?          @map("estimated_budget") @db.Decimal(12, 2)
  estimateProjectId  String?           @unique @map("estimate_project_id")
  scheduledAt        DateTime?         @map("scheduled_at")
  notes        String?
  convertedAt  DateTime?         @map("converted_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      CompanyCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  category      Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  estimateProject EstimateProject? @relation(fields: [estimateProjectId], references: [id], onDelete: SetNull)
  interventions Intervention[]

  @@index([companyId, status, createdAt])
  @@map("company_leads")
}

model CompanyCustomerDocument {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  fileKey    String   @map("file_key")
  type       String
  createdAt  DateTime @default(now()) @map("created_at")

  customer CompanyCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("company_customer_documents")
}

model PortalInvitation {
  id         String           @id @default(uuid())
  customerId String           @map("customer_id")
  token      String           @unique
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime         @map("expires_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  customer CompanyCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("portal_invitations")
}

model Intervention {
  id             String             @id @default(uuid())
  companyId      String             @map("company_id")
  customerId     String             @map("customer_id")
  technicianId   String?            @map("technician_id")
  number         String             @unique
  type           String
  description    String
  address        String
  status         InterventionStatus @default(NEW)
  scheduledAt    DateTime?          @map("scheduled_at")
  estimatedPrice Decimal?           @map("estimated_price") @db.Decimal(12, 2)
  finalPrice     Decimal?           @map("final_price") @db.Decimal(12, 2)
  internalNotes      String?            @map("internal_notes")
  sourceLeadId       String?            @map("source_lead_id")
  estimateProjectId  String?            @map("estimate_project_id")
  estimateStageId    String?            @map("estimate_stage_id")
  checklistProgress  Json?              @map("checklist_progress")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  company         Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        CompanyCustomer             @relation(fields: [customerId], references: [id])
  technician      CompanyMember?              @relation("TechnicianInterventions", fields: [technicianId], references: [id])
  sourceLead      CompanyLead?                @relation(fields: [sourceLeadId], references: [id], onDelete: SetNull)
  estimateProject EstimateProject?            @relation(fields: [estimateProjectId], references: [id], onDelete: SetNull)
  estimateStage   EstimateStage?              @relation(fields: [estimateStageId], references: [id], onDelete: SetNull)
  history    InterventionStatusHistory[]
  notes      InterventionNote[]
  photos     InterventionPhoto[]
  quotes     Quote[]
  invoice    CompanyInvoice?
  review     CompanyReview?

  @@index([companyId, status])
  @@index([technicianId, status])
  @@map("interventions")
}

model InterventionStatusHistory {
  id                String             @id @default(uuid())
  interventionId    String             @map("intervention_id")
  fromStatus        InterventionStatus? @map("from_status")
  toStatus          InterventionStatus @map("to_status")
  changedByMemberId String             @map("changed_by_member_id")
  note              String?
  changedAt         DateTime           @default(now()) @map("changed_at")

  intervention Intervention  @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  changedBy    CompanyMember @relation(fields: [changedByMemberId], references: [id])

  @@index([interventionId, changedAt])
  @@map("intervention_status_history")
}

model InterventionNote {
  id               String   @id @default(uuid())
  interventionId   String   @map("intervention_id")
  authorMemberId   String   @map("author_member_id")
  body             String
  isInternal       Boolean  @default(true) @map("is_internal")
  createdAt        DateTime @default(now()) @map("created_at")

  intervention Intervention  @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  author       CompanyMember @relation(fields: [authorMemberId], references: [id])

  @@index([interventionId, createdAt])
  @@map("intervention_notes")
}

model InterventionPhoto {
  id             String @id @default(uuid())
  interventionId String @map("intervention_id")
  fileKey        String @map("file_key")
  sortOrder      Int    @default(0) @map("sort_order")

  intervention Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  @@index([interventionId, sortOrder])
  @@map("intervention_photos")
}

model Quote {
  id             String      @id @default(uuid())
  companyId      String      @map("company_id")
  customerId     String      @map("customer_id")
  interventionId String?     @map("intervention_id")
  number         String      @unique
  status         QuoteStatus @default(DRAFT)
  total          Decimal     @db.Decimal(12, 2)
  validUntil     DateTime?   @map("valid_until")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer     CompanyCustomer    @relation(fields: [customerId], references: [id])
  intervention Intervention?      @relation(fields: [interventionId], references: [id])
  estimateProject EstimateProject?
  lines        QuoteLine[]

  @@index([companyId, status, createdAt])
  @@index([customerId])
  @@map("quotes")
}

model QuoteLine {
  id               String   @id @default(uuid())
  quoteId          String   @map("quote_id")
  companyServiceId String?  @map("company_service_id")
  description      String
  qty              Decimal  @db.Decimal(10, 2)
  unitPrice        Decimal  @map("unit_price") @db.Decimal(12, 2)
  vatRate          Decimal? @map("vat_rate") @db.Decimal(5, 2)

  quote          Quote           @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  companyService CompanyService? @relation(fields: [companyServiceId], references: [id])

  @@map("quote_lines")
}

model CompanyInvoice {
  id             String               @id @default(uuid())
  companyId      String               @map("company_id")
  interventionId String?              @unique @map("intervention_id")
  number         String               @unique
  amount         Decimal              @db.Decimal(12, 2)
  tvaAmount      Decimal              @map("tva_amount") @db.Decimal(12, 2)
  tvaRate        Decimal              @map("tva_rate") @db.Decimal(5, 2)
  paymentStatus  InvoicePaymentStatus @default(UNPAID) @map("payment_status")
  dueDate        DateTime?            @map("due_date")
  pdfFileKey     String?              @map("pdf_file_key")
  issuedAt       DateTime             @default(now()) @map("issued_at")

  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  intervention Intervention?     @relation(fields: [interventionId], references: [id])

  @@index([companyId, paymentStatus])
  @@index([companyId, issuedAt])
  @@map("company_invoices")
}

model Badge {
  id        String   @id @default(uuid())
  companyId String?  @map("company_id")
  code      String
  isActive  Boolean  @default(true) @map("is_active")
  awardedAt DateTime @default(now()) @map("awarded_at")
  expiresAt DateTime? @map("expires_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@map("badges")
}

model Payment {
  id          String             @id @default(uuid())
  companyId   String?            @map("company_id")
  productType PaymentProductType @map("product_type")
  amount      Decimal            @db.Decimal(12, 2)
  currency    String             @default("MDL")
  status      String             @default("PENDING")
  externalId  String?            @map("external_id")
  createdAt   DateTime           @default(now()) @map("created_at")

  @@map("payments")
}

model CompanyReview {
  id             String       @id @default(uuid())
  companyId      String       @map("company_id")
  customerId     String       @map("customer_id")
  interventionId String       @unique @map("intervention_id")
  authorUserId   String       @map("author_user_id")
  clientName     String?      @map("client_name")
  rating         Int
  comment        String?
  status         ReviewStatus @default(VISIBLE)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer     CompanyCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  intervention Intervention    @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  author       User            @relation("ReviewAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([companyId, status, createdAt])
  @@index([authorUserId])
  @@map("company_reviews")
}

model EstimateBlueprint {
  id         String   @id @default(uuid())
  categoryId String   @unique @map("category_id")
  name       String
  version    Int      @default(1)
  config     Json
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  projects EstimateProject[]

  @@map("estimate_blueprints")
}

model EstimateProject {
  id                String                @id @default(uuid())
  companyId         String                @map("company_id")
  customerId        String                @map("customer_id")
  categoryId        String                @map("category_id")
  blueprintId       String?               @map("blueprint_id")
  quoteId           String?               @unique @map("quote_id")
  number            String                @unique
  title             String
  status            EstimateProjectStatus @default(DRAFT)
  siteType          String?               @map("site_type")
  address           String?
  marginPct         Decimal               @default(0) @map("margin_pct") @db.Decimal(5, 2)
  laborTotal        Decimal               @default(0) @map("labor_total") @db.Decimal(12, 2)
  materialTotal     Decimal               @default(0) @map("material_total") @db.Decimal(12, 2)
  grandTotal        Decimal               @default(0) @map("grand_total") @db.Decimal(12, 2)
  validUntil        DateTime?             @map("valid_until")
  diagnosticAnswers Json?                 @map("diagnostic_answers")
  requiresManualReview Boolean            @default(false) @map("requires_manual_review")
  calculationTrace   Json?                @map("calculation_trace")
  clientFeedback     Json?                @map("client_feedback")
  notes             String?
  tvaRate           Decimal?              @map("tva_rate") @db.Decimal(5, 2)
  tvaAmount         Decimal               @default(0) @map("tva_amount") @db.Decimal(12, 2)
  grandTotalWithVat Decimal               @default(0) @map("grand_total_with_vat") @db.Decimal(12, 2)
  version           Int                   @default(1)
  clientMutationId  String?               @map("client_mutation_id")
  clientDraftId     String?               @map("client_draft_id")
  actualsLockedAt   DateTime?             @map("actuals_locked_at")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  company      Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer     CompanyCustomer         @relation(fields: [customerId], references: [id])
  category     Category                @relation(fields: [categoryId], references: [id])
  blueprint    EstimateBlueprint?      @relation(fields: [blueprintId], references: [id], onDelete: SetNull)
  quote        Quote?                  @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  sitePlan     EstimateSitePlan?
  stages       EstimateStage[]
  measurements EstimateMeasurement[]
  interventions Intervention[]
  sourceLead   CompanyLead?
  appliedMutations EstimateAppliedMutation[]
  receipts     EstimateReceipt[]

  @@index([companyId, status, createdAt])
  @@index([categoryId])
  @@map("estimate_projects")
}

model EstimateAppliedMutation {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  mutationId    String   @map("mutation_id")
  kind          String
  appliedAt     DateTime @default(now()) @map("applied_at")
  clientDraftId String?  @map("client_draft_id")

  project EstimateProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, mutationId], map: "estimate_applied_mutations_project_mutation_idx")
  @@index([appliedAt], map: "estimate_applied_mutations_applied_at_idx")
  @@map("estimate_applied_mutations")
}

model EstimateSitePlan {
  id        String   @id @default(uuid())
  projectId String   @unique @map("project_id")
  version   Int      @default(1)
  plan2d    Json     @map("plan_2d")
  plan3d    Json?    @map("plan_3d")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project EstimateProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("estimate_site_plans")
}

model EstimateStage {
  id           String            @id @default(uuid())
  projectId    String            @map("project_id")
  sortOrder    Int               @map("sort_order")
  code         String
  name         String
  kind         EstimateStageKind @default(MIXED)
  description  String?
  laborHours   Decimal?          @map("labor_hours") @db.Decimal(8, 2)
  laborRate    Decimal?          @map("labor_rate") @db.Decimal(12, 2)
  laborCost    Decimal           @default(0) @map("labor_cost") @db.Decimal(12, 2)
  materialCost Decimal           @default(0) @map("material_cost") @db.Decimal(12, 2)
  stageTotal   Decimal           @default(0) @map("stage_total") @db.Decimal(12, 2)
  durationDays Int?              @map("duration_days")
  checklist    Json?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  project       EstimateProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lines         EstimateLine[]
  interventions Intervention[]

  @@index([projectId, sortOrder])
  @@map("estimate_stages")
}

enum EstimateLineActualStatus {
  PENDING
  PURCHASED
  NO_RECEIPT
  SKIPPED
  VERIFIED
}

model EstimateLine {
  id             String   @id @default(uuid())
  stageId        String   @map("stage_id")
  description    String
  qty            Decimal  @db.Decimal(10, 2)
  unit           String   @default("buc")
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal      Decimal  @map("line_total") @db.Decimal(12, 2)
  source         String   @default("manual")
  sortOrder      Int      @default(0) @map("sort_order")
  materialStore  String?  @map("material_store")
  receiptFileKey String?  @map("receipt_file_key")
  vatRate        Decimal? @map("vat_rate") @db.Decimal(5, 2)
  actualUnitPrice         Decimal?                 @map("actual_unit_price") @db.Decimal(12, 2)
  actualLineTotal         Decimal?                 @map("actual_line_total") @db.Decimal(12, 2)
  actualQty               Decimal?                 @map("actual_qty") @db.Decimal(10, 2)
  actualNotes             String?                  @map("actual_notes")
  actualStatus            EstimateLineActualStatus @default(PENDING) @map("actual_status")
  actualStatusUpdatedAt   DateTime?                @map("actual_status_updated_at")
  actualStatusByMemberId  String?                  @map("actual_status_by_member_id")
  receiptId               String?                  @map("receipt_id")

  stage   EstimateStage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  receipt EstimateReceipt? @relation(fields: [receiptId], references: [id], onDelete: SetNull)

  @@index([stageId, sortOrder])
  @@index([receiptId], map: "estimate_lines_receipt_idx")
  @@index([actualStatus], map: "estimate_lines_actual_status_idx")
  @@map("estimate_lines")
}

model EstimateReceipt {
  id                  String    @id @default(uuid())
  companyId           String    @map("company_id")
  projectId           String    @map("project_id")
  fileKey             String?   @map("file_key")
  store               String
  totalAmount         Decimal   @map("total_amount") @db.Decimal(12, 2)
  purchaseDate        DateTime  @map("purchase_date")
  addedByMemberId     String    @map("added_by_member_id")
  verified            Boolean   @default(false)
  verifiedByMemberId  String?   @map("verified_by_member_id")
  verifiedAt          DateTime? @map("verified_at")
  parsingRequired     Boolean   @default(false) @map("parsing_required")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt        @map("updated_at")

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project EstimateProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lines   EstimateLine[]

  @@index([projectId], map: "estimate_receipts_project_idx")
  @@index([companyId, purchaseDate], map: "estimate_receipts_company_purchase_idx")
  @@map("estimate_receipts")
}

model EstimateMeasurement {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  roomKey   String?  @map("room_key")
  key       String
  label     String?
  value     Decimal  @db.Decimal(12, 2)
  unit      String
  createdAt DateTime @default(now()) @map("created_at")

  project EstimateProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, key])
  @@map("estimate_measurements")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}
